# LLM — Groq (default for Phase 4+)
LLM_PROVIDER=groq
LLM_API_KEY=                         # Groq API key from https://console.groq.com/keys
LLM_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
LLM_MAX_RETRIES=1

# Optional: local Ollama (no API key)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Data
DATA_CACHE_PATH=data/restaurants.parquet
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Filtering / recommendations
MAX_CANDIDATES=30
TOP_K_RESULTS=5

# CORS — comma-separated frontend URLs (Railway / production)
# Use * only for demos. Example:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
